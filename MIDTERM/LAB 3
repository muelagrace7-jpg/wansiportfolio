<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Request for Proposal</title>
<style>


</style>
</head>
<body>

<fieldset>
    

<legend><h1 style="color: blue">Request for Proposal</h1></legend>

<form >
<table >
    <tr>
        <td> Your Company:</td>
        <td><input type="text" placeholder="Enter company name" name="company"></td>
    </tr>

    <tr>
        <td> Email:</td>
        <td><input type="email" placeholder="Enter you Email" name="email"></td>
    </tr>

    <tr>
        <td> Username:</td>
        <td><input type="text" placeholder="Enter your Username" name="username" ></td>
    </tr>

    <tr>
        <td> Password:</td>
        <td><input type="password" placeholder="Enter your Password" name="password"></td>
    </tr>
    
    <tr>
         <td>Birthday:</td>
         <td><input type="date" name="Birthday"  ></td>
        
        
    </tr>


    <tr>
        <td> Your business:</td>
        <td>
            <textarea rows="5" cols="40">
            </textarea>
        </td>
    </tr>

    <tr>
        <td> Company size:</td>
        <td>
            <input type="radio" name="size"> less than 10 <br>
            <input type="radio" name="size"> 11 to 50 <br>
            <input type="radio" name="size"> 50 to 200 <br>
            <input type="radio" name="size"> Over 200
        </td>
    </tr>

    <tr>
        <td> Services:</td>
        <td>
            <input type="checkbox"> Brand Identity 
            <input type="checkbox"> New Website 
            <input type="checkbox"> Web Redesign
        </td>
    </tr>

    <tr>
        <td>Timeline:</td>
        <td>
            <select>
                <option>Immediately</option>
                <option>1-2 weeks</option>
                <option>3-6 weeks</option>
                <option>7-2 months</option>
            </select>
        </td>
    </tr>


    <tr>
            <td></td>
            <td>
                <input type="submit" value="Send to dev/design">
            </td>
        </tr>




</table>
</form>

</fieldset>

</body>
</html>